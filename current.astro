---
import Base from "../layouts/Base.astro";
import "../styles/index.scss";
---

<Base>
  <header class="site-header" id="siteHeader">
    <div class="header-shell">
      <!-- Desktop -->
      <div class="desktop-wrap">
        <!-- Full desktop nav -->
        <nav
          class="desktop-nav"
          id="desktopNav"
          aria-label="Primary navigation"
        >
          <a href="/" class="avatar" aria-label="Home">
            <img
              src="https://framerusercontent.com/images/IUYreEo8ON7qCLgK2tgDOW0xoI.jpg"
              alt="Avatar"
            />
          </a>

          <div class="desktop-links">
            <a class="nav-link" href="/">Home</a>
            <a class="nav-link" href="/about">About</a>
            <a class="nav-link" href="/projects">Projects</a>
            <a class="nav-link" href="/blogs">Blogs</a>
          </div>

          <a class="contact-btn desktop-contact" href="/#contact">Contact</a>
        </nav>

        <!-- Compact desktop nav (shown on scroll down) -->
        <div class="desktop-compact" id="desktopCompact" aria-hidden="true">
          <a href="/" class="avatar" aria-label="Home">
            <img
              src="https://framerusercontent.com/images/IUYreEo8ON7qCLgK2tgDOW0xoI.jpg"
              alt="Avatar"
            />
          </a>

          <div class="compact-status">
            <span>Available for work</span>
            <span class="dot" aria-hidden="true"></span>
          </div>
        </div>
      </div>

      <!-- Mobile -->
      <nav class="mobile-nav" aria-label="Mobile navigation">
        <div class="mobile-shell">
          <div class="mobile-topbar">
            <a href="/" class="avatar" aria-label="Home">
              <img
                src="https://framerusercontent.com/images/IUYreEo8ON7qCLgK2tgDOW0xoI.jpg"
                alt="Avatar"
              />
            </a>

            <div class="mobile-status">
              <span>Available for work</span>
              <span class="dot" aria-hidden="true"></span>
            </div>

            <button
              id="menuToggle"
              class="menu-toggle"
              type="button"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="mobileMenu"
            >
              <span class="bar top" aria-hidden="true"></span>
              <span class="bar bottom" aria-hidden="true"></span>
            </button>
          </div>

          <div class="mobile-panel" id="mobileMenu" aria-hidden="true">
            <div class="mobile-links">
              <a class="nav-link" href="/">Home</a>
              <a class="nav-link" href="/about">About</a>
              <a class="nav-link" href="/projects">Projects</a>
              <a class="nav-link" href="/blogs">Blogs</a>
            </div>

            <div class="mobile-contact-wrap">
              <a class="contact-btn mobile-contact" href="/#contact">Contact</a>
            </div>
          </div>
        </div>
      </nav>
    </div>
  </header>

  <main id="home">
    <!-- hero -->

    <!-- top status pill (desktop-style header element from the page) -->
    <div class="status-pill" aria-label="Availability">
      <span class="status-avatar">
        <img
          src="https://framerusercontent.com/images/IUYreEo8ON7qCLgK2tgDOW0xoI.jpg"
          alt="Avatar"
        />
      </span>
      <span class="status-text">Available for work</span>
      <span class="status-dot" aria-hidden="true"></span>
    </div>

    <!-- Shared floating card (desktop only animation) -->
    <div class="floating-stage" aria-hidden="true">
      <div class="floating-card" id="floatingCard">
        <div class="floating-face floating-face-front" id="floatingFaceFront">
          <img
            src="https://framerusercontent.com/images/qrxY8NagVO40NBrdhFEGgFR3PYY.jpg?width=620&height=630"
            alt=""
          />
        </div>

        <div class="floating-face floating-face-back" id="floatingFaceBack">
          <img
            src="https://framerusercontent.com/images/qbjsnnvP9w7UaA2syp36oUe8OSo.jpg"
            alt=""
          />
        </div>

        <div class="floating-badge" id="floatingBadge">
          <span>Hi</span>
        </div>
      </div>
    </div>

    <!-- HERO -->
    <section class="hero" id="hero">
      <div class="hero-inner">
        <div class="hero-copy hero-copy-left">
          <p class="hero-name">DUNCAN ROBERT</p>
          <h1 class="hero-title">DIGITAL</h1>
        </div>

        <!-- desktop spacer for shared floating card -->
        <div
          class="shared-card-slot shared-card-slot-hero"
          id="slotHero"
          aria-hidden="true"
        >
        </div>

        <div class="hero-copy hero-copy-right">
          <h1 class="hero-title">DESIGNER</h1>
          <p class="hero-subtitle">
            I'm a US-based digital designer and Framer developer
          </p>
        </div>

        <!-- mobile-only inline portrait -->
        <div class="hero-mobile-card">
          <div class="hero-mobile-image">
            <img
              src="https://framerusercontent.com/images/qrxY8NagVO40NBrdhFEGgFR3PYY.jpg?width=620&height=630"
              alt="Portrait of Duncan"
            />
            <div class="hero-mobile-badge">🖐</div>
          </div>
        </div>
      </div>
    </section>

