---
import Base from "../layouts/Base.astro";
import "../styles/styles.scss";
import "../styles/index.scss";
---

<Base>
  <!-- ─────────────────────────────────────
       LZ Navigation
       ───────────────────────────────────── -->

  <header id="lz-navigation">
    <div class="lz-container">
      <nav class="lz-navigation" aria-label="Primary navigation">
        <div class="lz-navigation-topbar">
          <a class="lz-avatar" href="/" aria-label="Home">
            <img src="/img/lz-logo.svg" alt="Avatar" />
          </a>

          <div class="lz-navigation-status">
            <span>Available for work</span>
            <span class="lz-status-dot" aria-hidden="true"></span>
          </div>

          <button
            id="lz-menu-toggle-button"
            class="lz-menu-toggle-button"
            type="button"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="lz-navigation-panel"
          >
            <span class="lz-menu-bar lz-menu-bar-top" aria-hidden="true"></span>
            <span class="lz-menu-bar lz-menu-bar-bottom" aria-hidden="true"
            ></span>
          </button>

          <div class="lz-navigation-links" aria-hidden="true">
            <a class="lz-navigation-link" href="/">Home</a>
            <a class="lz-navigation-link" href="#lz-home-about">About</a>
            <a class="lz-navigation-link" href="#lz-home-projects">Projects</a>
          </div>

          <a
            class="lz-contact-button lz-navigation-contact-button"
            href="#lz-home-contact"
            aria-hidden="true"
          >
            Contact
          </a>
        </div>

        <div
          id="lz-navigation-panel"
          class="lz-navigation-panel"
          aria-hidden="true"
        >
          <div class="lz-navigation-panel-links">
            <a class="lz-navigation-link" href="/">Home</a>
            <a class="lz-navigation-link" href="/about">About</a>
            <a class="lz-navigation-link" href="/projects">Projects</a>
          </div>

          <div class="lz-navigation-panel-contact-wrapper">
            <a
              class="lz-contact-button lz-navigation-panel-contact-button"
              href="/#lz-home-contact"
            >
              Contact
            </a>
          </div>
        </div>
      </nav>
    </div>
  </header>

  <main id="lz-home">
    <!-- ─────────────────────────────────────
         LZ Shared Floating Card
         ───────────────────────────────────── -->

    <div class="lz-floating-stage" aria-hidden="true">
      <div id="lz-floating-card" class="lz-floating-card">
        <div
          id="lz-floating-face-front"
          class="lz-floating-face lz-floating-face-front"
        >
          <img src="/img/lz-portrait.jpg" alt="" />
        </div>

        <div
          id="lz-floating-face-back"
          class="lz-floating-face lz-floating-face-back"
        >
          <img
            src=""
            alt=""
          />
        </div>

        <div id="lz-floating-badge" class="lz-floating-badge">
          <span>Hi</span>
        </div>
      </div>
    </div>

    <!-- ─────────────────────────────────────
         LZ Hero
         ───────────────────────────────────── -->

    <section id="lz-home-hero">
      <div class="lz-container">
        <div class="lz-content lz-content-left">
          <p class="lz-name">Laurenz Sinchongco</p>
          <p class="lz-title" aria-hidden="true">Full-stack</p>
        </div>

        <div
          id="lz-hero-card-slot"
